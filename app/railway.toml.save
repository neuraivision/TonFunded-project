[build]
builder = "RAILPACK"
[build.env]
RAILPACK_INSTALL_CMD = "npm ci --legacy-peer-deps"
[build]
builder = "nixpacks"
buildCommand = "npm install --legacy-peer-deps && npm run build"

[deploy]
startCommand = "npx serve -s dist -l $PORT"
restartPolicyType = "on_failure"
restartPolicyMaxRetries = 3
